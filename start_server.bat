@echo off
echo Starting local server... It will run until you close this window.
start http://localhost:8000/
powershell -ExecutionPolicy Bypass -NoProfile -Command "$root=$pwd.Path; $listener = New-Object System.Net.HttpListener; $listener.Prefixes.Add('http://localhost:8000/'); $listener.Start(); Write-Host 'Listening on http://localhost:8000/'; try { while($listener.IsListening) { $context = $listener.GetContext(); $req = $context.Request; $res = $context.Response; $path = $req.RawUrl; if($path -contains '?') { $path = $path.Split('?')[0] }; $path = $path.TrimStart('/'); if([string]::IsNullOrEmpty($path)) { $path = 'index.html' }; $fullPath = Join-Path $root $path; if (Test-Path $fullPath -PathType Leaf) { $ext = [System.IO.Path]::GetExtension($fullPath).ToLower(); $mime = 'application/octet-stream'; if($ext -eq '.html'){ $mime='text/html' } elseif($ext -eq '.css'){ $mime='text/css' } elseif($ext -eq '.js'){ $mime='application/javascript' } elseif($ext -eq '.png'){ $mime='image/png' } elseif($ext -eq '.svg'){ $mime='image/svg+xml' }; $res.ContentType = $mime; $bytes = [System.IO.File]::ReadAllBytes($fullPath); $res.ContentLength64 = $bytes.Length; $res.OutputStream.Write($bytes, 0, $bytes.Length); $res.OutputStream.Close() } else { $res.StatusCode = 404; $res.Close() } } } catch { Write-Host $_.Exception.Message }"
